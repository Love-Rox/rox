    "@simplewebauthn/types": "^12.0.0",
    "blurhash": "^2.0.5",
    "bullmq": "^5.76.8",
    "drizzle-orm": "^0.45.2",
    "eventsource": "^4.1.0",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "shared": "workspace:*",
    "sharp": "^0.34.5",
